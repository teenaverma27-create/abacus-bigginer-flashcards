<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Abacus Flashcards</title>

<style>
body {
  font-family: Arial, sans-serif;
  text-align: center;
  background: #f4f6f8;
}

.container {
  margin-top: 30px;
}

.card {
  width: 280px;
  height: 320px;
  margin: auto;
  perspective: 1000px;
}

.inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s;
  transform-style: preserve-3d;
}

.flipped {
  transform: rotateY(180deg);
}

.front, .back {
  position: absolute;
  width: 100%;
  height: 100%;
  background: white;
  border-radius: 12px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back {
  transform: rotateY(180deg);
  font-size: 48px;
  font-weight: bold;
}

.abacus {
  display: flex;
  gap: 20px;
}

.rod {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bead {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  margin: 3px;
}

.upper {
  background: #444;
}

.lower {
  background: orange;
}

.active {
  transform: translateY(10px);
}

button {
  margin: 15px 5px;
  padding: 10px 15px;
  border: none;
  border-radius: 6px;
  background: #007bff;
  color: white;
  cursor: pointer;
}

button:hover {
  background: #0056b3;
}
</style>
</head>

<body>

<div class="container">
  <h2>Abacus Flashcards</h2>
  <p id="progress"></p>

  <div class="card" onclick="flipCard()">
    <div class="inner" id="cardInner">
      <div class="front" id="front"></div>
      <div class="back" id="back"></div>
    </div>
  </div>

  <div>
    <button onclick="prevCard()">Prev</button>
    <button onclick="nextCard()">Next</button>
  </div>
</div>

<script>
let cards = [];

// Generate 25 numbers (0–24)
for (let i = 0; i < 25; i++) {
  cards.push(i);
}

let current = 0;

function createAbacus(num) {
  let tens = Math.floor(num / 10);
  let ones = num % 10;

  return `
    <div class="abacus">
      ${createRod(tens)}
      ${createRod(ones)}
    </div>
  `;
}

function createRod(value) {
  let upperActive = value >= 5;
  let lowerCount = upperActive ? value - 5 : value;

  let lowerBeads = '';
  for (let i = 0; i < 4; i++) {
    lowerBeads += `<div class="bead lower ${i < lowerCount ? 'active' : ''}"></div>`;
  }

  return `
    <div class="rod">
      <div class="bead upper ${upperActive ? 'active' : ''}"></div>
      ${lowerBeads}
    </div>
  `;
}

function renderCard() {
  let num = cards[current];

  document.getElementById("front").innerHTML = createAbacus(num);
  document.getElementById("back").innerText = num;
  document.getElementById("progress").innerText = (current + 1) + " / 25";

  document.getElementById("cardInner").classList.remove("flipped");
}

function flipCard() {
  document.getElementById("cardInner").classList.toggle("flipped");
}

function nextCard() {
  current = (current + 1) % cards.length;
  renderCard();
}

function prevCard() {
  current = (current - 1 + cards.length) % cards.length;
  renderCard();
}

renderCard();
</script>

</body>
</html>
